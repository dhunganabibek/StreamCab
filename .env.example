# Data source
# Keep local raw parquet data at this host path.
# The container path is fixed to /opt/streamcab/data/raw-data/parquet.
RAW_DATA_HOST_PATH=./data/raw-data
AWS_REGION=us-east-1

# Optional overrides
MODEL_FILE=/opt/streamcab/models/traffic_model.joblib
ZONE_CENTROIDS_FILE=/opt/streamcab/data/reference/zone_centroids.csv

# Advanced mode (optional): train directly from S3 instead of local mount.
# RAW_DATA_DIR=s3://your-bucket/streamcab/parquet

# Kafka 
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=taxi-trips

# Host port binding for Postgres container.
# Use 5432 only if your machine does not already run Postgres locally.
POSTGRES_HOST_PORT=5433

# Tuning
REPLAY_SLEEP_SECONDS=0.15
PREDICTION_INTERVAL_SECONDS=30
WRITE_LIVE_TRIPS_FROM_PRODUCER=false
LIVE_TRIPS_INSERT_BATCH_SIZE=200
LIVE_TRIPS_FLUSH_INTERVAL_SECONDS=1.0
LIVE_SAMPLE_LIMIT=200

# Limit parquet files loaded during training 
MAX_FILES=
