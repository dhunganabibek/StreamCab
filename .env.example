# ── Data source — pick ONE of the three modes ────────────────────────────────
#
# Mode 1 — data lives inside the repo (default, teammates with cloned repo)
#   RAW_DATA_HOST_PATH=./data/raw-data
#   RAW_DATA_DIR=/opt/streamcab/data/raw-data/parquet
#
# Mode 2 — data on an external drive or symlink (override host mount)
#   RAW_DATA_HOST_PATH=/Volumes/PNY/StreamCab-data
#   RAW_DATA_DIR=/opt/streamcab/data/raw-data/parquet
#
# Mode 3 — public S3 bucket (no credentials, no local data needed)
#   RAW_DATA_HOST_PATH=./data/raw-data   ← ignored by the container, keep default
#   RAW_DATA_DIR=s3://your-bucket/streamcab/parquet

RAW_DATA_HOST_PATH=./data/raw-data
RAW_DATA_DIR=/opt/streamcab/data/raw-data/parquet
AWS_REGION=us-east-1

# Container-internal data paths 
CONTAINER_ROOT=/opt/streamcab
MODEL_OUTPUT_DIR=/opt/streamcab/models
AGGREGATE_DIR=/opt/streamcab/data/processed/traffic_agg
CHECKPOINT_DIR=/opt/streamcab/data/checkpoints/traffic_agg
MODEL_FILE=/opt/streamcab/models/traffic_model.joblib
PREDICTIONS_FILE=/opt/streamcab/models/realtime_predictions.parquet
METRICS_FILE=/opt/streamcab/models/metrics.json
LIVE_LOG_FILE=/opt/streamcab/models/live_trips.json
ZONE_CENTROIDS_FILE=/opt/streamcab/data/reference/zone_centroids.csv

# Kafka 
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=taxi-trips

# Tuning
REPLAY_SLEEP_SECONDS=0.15
PREDICTION_INTERVAL_SECONDS=30

# Limit parquet files loaded during training 
MAX_FILES=
