# ── Data ────────────────────────────────────────────────────────────────────
# Host folder mounted into containers for raw parquet files.
# The default (./data/raw-data) is resolved relative to compose.yml, so it
# works automatically from any clone location — no changes needed.
# Override with an absolute path only if your data lives elsewhere:
#   RAW_DATA_HOST_PATH=/Volumes/MyDrive/nyc-taxi-data
RAW_DATA_HOST_PATH=./data/raw-data

# Postgres host port (5433 avoids conflicts with a local Postgres on 5432)
POSTGRES_HOST_PORT=5433

# Set to false to allow Spark to continue if Kafka data was lost/topic recreated
KAFKA_FAIL_ON_DATA_LOSS=false

# ── Tuning (all have sane code defaults — override only if needed) ───────────
# Seconds between emitting each event from the producer
REPLAY_SLEEP_SECONDS=0.15

# Seconds between predictor inference passes
PREDICTION_INTERVAL_SECONDS=30

# Set to true to have the producer write live_trips directly (bypasses consumer)
WRITE_LIVE_TRIPS_FROM_PRODUCER=false

# Consumer batch settings
LIVE_TRIPS_INSERT_BATCH_SIZE=200
LIVE_TRIPS_FLUSH_INTERVAL_SECONDS=1.0

# ── Training (train-once only) ───────────────────────────────────────────────
# Limit parquet files loaded during training (leave blank for all files)
MAX_FILES=

# Path to training data inside the train-once container.
# Defaults to /opt/streamcab/data/raw-data/parquet (the mounted RAW_DATA_HOST_PATH).
# Set to an S3 URL to train from cloud storage instead: s3://your-bucket/streamcab/parquet
# RAW_DATA_DIR=

# AWS region for S3 training data
AWS_REGION=us-east-1
